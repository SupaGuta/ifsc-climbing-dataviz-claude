# IFSC API session — leave blank and run `python -m wcl_data auth` to populate
# automatically, or paste manually from DevTools on ifsc.results.info.
# These rotate; expect to refresh every few months.
WCL_CSRF_TOKEN=
WCL_SESSION_COOKIE=
WCL_REFERER=https://ifsc.results.info

# Crawl tuning — 50 is the default; 50-100 is the useful range. Override per run with `--workers N`.
WCL_MAX_WORKERS=50
WCL_REQUEST_TIMEOUT=120

# Where the warehouse lives
WCL_DB_PATH=data/wcl.sqlite

# Treat rows older than this as stale during `hydrate`
WCL_STALE_DAYS=30

# Grace period (days past date_end) within which pull-new still re-fetches an event.
# Catches late result corrections without re-fetching ancient containers.
WCL_GRACE_DAYS=15
